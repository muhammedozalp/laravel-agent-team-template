APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local vhost — add to /etc/hosts:  127.0.0.1 examplesite.local staging.examplesite.local
# (guides/docker.md; https uses an auto self-signed cert, mkcert for a trusted one)
APP_HOST=examplesite.local
APP_URL=https://examplesite.local

# Docker (docker-compose.yml) — match your host user for bind-mount ownership
DOCKER_UID=1000
DOCKER_GID=1000
APP_PORT=8080
APP_HTTPS_PORT=443
VITE_PORT=5173
MAILPIT_UI_PORT=8025
DB_FORWARD_PORT=54320

# Browser/e2e tests: empty = test the local app; set to a deployed URL to smoke-test
# that environment instead (e.g. https://staging.example.com) — guides/testing.md
E2E_BASE_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Approval gate: when true, new registrations wait until an admin approves
# them from /admin (context/guides/auth.md). Off = instant registration.
REQUIRE_ACCOUNT_APPROVAL=false

# Error monitoring — empty = disabled (dev default). Set the project DSN in
# production; see context/guides/deploy.md release checklist.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
