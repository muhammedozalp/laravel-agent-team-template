# Production environment TEMPLATE (committed — no real values here).
# Workflow (context/guides/deploy.md § Secrets):
#   1. cp .env.production.example .env.production   (gitignored)
#   2. fill real values
#   3. php artisan env:encrypt --env=production      -> commit the .encrypted file,
#      store the printed key in your password manager + the GitHub secret
#   4. scripts/deploy.sh decrypts it on the server at release time

APP_NAME=Example
APP_ENV=production
APP_KEY=                       # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://example.com
APP_DOMAIN=example.com         # Caddy vhost (auto Let's Encrypt)

# GHCR images (set by/matching .github/workflows/deploy.yml)
APP_IMAGE=ghcr.io/OWNER/REPO-app:latest
WEB_IMAGE=ghcr.io/OWNER/REPO-web:latest

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=                   # long random value

SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# Real SMTP (Mailpit is dev-only)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

REQUIRE_ACCOUNT_APPROVAL=false

SENTRY_DSN=                    # error monitoring — set it, it's why Sentry ships
SENTRY_TRACES_SAMPLE_RATE=0.2
