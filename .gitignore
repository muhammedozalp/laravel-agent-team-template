# --- template additions ---
# secrets: commit only the template
.env.*
!.env.example

# local Claude Code settings stay local
.claude/settings.local.json

# agent team: durable charter/roles/templates are tracked;
# volatile board/logs/handoff never enter PRs (context/agent_team/index.md)
context/agent_team/board.md
context/agent_team/log-*.md
context/agent_team/handoff.md
docker/nginx/certs/*
!docker/nginx/certs/.gitkeep

# browser-test artifacts
tests/Browser/Screenshots/

# React kit generated output (Wayfinder + SSR)
/bootstrap/ssr
/resources/js/actions
/resources/js/routes
/resources/js/wayfinder

# production env: template + encrypted file are committed, plaintext never
!.env.production.example
!.env.production.encrypted
