# envsubst'd by the official nginx entrypoint: ${APP_HOST} comes from the
# environment; nginx's own $vars (no braces) are left alone.

# Plain HTTP — host-port fallback (http://localhost:8080) and any unnamed host.
server {
    listen 80;
    server_name _;
    include /etc/nginx/snippets/security-headers.conf;
    include /etc/nginx/snippets/laravel.conf;
}

# HTTPS vhost — https://${APP_HOST} and any subdomain (e.g. staging.${APP_HOST}).
# Certs: auto self-signed on first start (docker/nginx/09-selfsigned.sh);
# replace with mkcert output in docker/nginx/certs/ for a browser-trusted lock.
server {
    listen 443 ssl;
    http2 on;
    server_name ${APP_HOST} *.${APP_HOST};

    ssl_certificate     /etc/nginx/certs/${APP_HOST}.pem;
    ssl_certificate_key /etc/nginx/certs/${APP_HOST}-key.pem;

    include /etc/nginx/snippets/security-headers.conf;
    include /etc/nginx/snippets/laravel.conf;
}
